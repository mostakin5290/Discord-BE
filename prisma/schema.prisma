generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  firstName String
  lastName  String
  username  String  @unique
  imageUrl  String?

  bio String? @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
