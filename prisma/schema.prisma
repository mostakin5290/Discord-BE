generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  firstName String
  lastName  String
  username  String  @unique
  imageUrl  String?
  password  String?
  provider  String?
  socialId  String?
  accessToken String?
  refreshToken String?



  bio String? @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
